#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'

log="$HOME/.local/state/indigo/indigo.log"

run_samply() {
  cargo build --profile profile --bin indigo
  samply record -- ./target/profile/indigo --log-filter info,indigo_core=debug,indigo=debug "$@"
}

run() {
  cargo run --bin indigo -- --log-filter info,indigo_core=debug,indigo=debug "$@"
}

print_log() {
  if [ -e "$log" ]; then
    cat "$log"
  fi
}

rm -f "$log"

trap print_log EXIT

# run_samply "$@"
run "$@"
